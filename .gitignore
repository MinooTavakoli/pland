# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# editor files
.vscode
.idea
.cursor
.cursorrules
.cursorrules.md
.cursorrules.txt
.cursorrules.yml

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma
/docs

# server storage (runtime logs & uploaded files)
/storage/logs/*
!/storage/logs/.gitkeep
/public/uploads/*
!/public/uploads/.gitkeep